# Copy this file to `.env` for local-only use.
# Never commit, print, or share real secrets.
# Keep this template placeholder-only.
#
# Docker Compose overrides a few values internally for containers
# (`DATABASE_URL`, `REDIS_URL`, `NGROK_API_URL`), so the defaults below stay
# friendly for direct local development.

# Application settings
PROJECT_NAME=Finance Assistant Bot
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
TELEGRAM_BOT_TOKEN=changeme-telegram-bot-token
TELEGRAM_BOT_USERNAME=FinanceAssistantBot
TELEGRAM_WEBHOOK_SECRET=changeme-webhook-secret
WEBHOOK_BASE_URL=
SENTRY_DSN=
DEFAULT_CURRENCY=UAH
DEFAULT_LANGUAGE=uk
DEFAULT_THEME=dark

# Ngrok integration
NGROK_AUTHTOKEN=changeme-ngrok-authtoken
NGROK_API_URL=http://localhost:4040
NGROK_TUNNEL_NAME=command_line

# Database
DATABASE_URL=sqlite+aiosqlite:///./app.db

# Redis / cache
REDIS_URL=redis://localhost:6379/0

# Scheduler & analytics
SCHEDULER_TZ=Europe/Kyiv
EXPORT_DIR=exports
REPORT_TIMEZONE=Europe/Kyiv

# Security / admin
ADMIN_API_KEY=changeme-admin-key

# AI integrations
OPENAI_API_KEY=changeme-openai-key
OPENAI_MODEL=gpt-4o-mini

# Web App
WEB_APP_URL=
WEB_SESSION_SECRET=changeme-session-secret
WEB_SESSION_TTL_SECONDS=604800
